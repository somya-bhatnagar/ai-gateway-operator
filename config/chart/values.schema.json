{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/opendatahub-io/ai-gateway-operator/cmd/chartgen/values",
  "$ref": "#/$defs/Values",
  "$defs": {
    "ImageSpec": {
      "properties": {
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        },
        "fullRef": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "repository",
        "tag"
      ]
    },
    "ResourceList": {
      "properties": {
        "cpu": {
          "type": "string"
        },
        "memory": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ResourceSpec": {
      "properties": {
        "limits": {
          "$ref": "#/$defs/ResourceList"
        },
        "requests": {
          "$ref": "#/$defs/ResourceList"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ServiceAccountSpec": {
      "properties": {
        "name": {
          "type": "string"
        },
        "annotations": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Values": {
      "properties": {
        "image": {
          "$ref": "#/$defs/ImageSpec"
        },
        "replicas": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "resources": {
          "$ref": "#/$defs/ResourceSpec"
        },
        "leaderElect": {
          "type": "boolean",
          "default": true
        },
        "serviceAccount": {
          "$ref": "#/$defs/ServiceAccountSpec"
        },
        "nameOverride": {
          "type": "string",
          "default": ""
        },
        "fullnameOverride": {
          "type": "string",
          "default": ""
        },
        "operatorNamespace": {
          "type": "string",
          "default": ""
        },
        "imagePullSecret": {
          "type": "string"
        },
        "config": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "image",
        "replicas",
        "resources",
        "leaderElect",
        "serviceAccount"
      ]
    }
  }
}